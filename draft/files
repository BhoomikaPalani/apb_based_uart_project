// driver class         

class driver extends uvm_driver#(xtn);

	`uvm_component_utils(driver)

	virtual uart_if.DRV_MP vif;

	agent_config agt_cfg;
	
	function new(string name="driver",uvm_component parent);
		super.new(name,parent);
	endfunction

	function void build_phase(uvm_phase phase);
		if(!uvm_config_db#(agent_config)::get(this,"","agent_config",agt_cfg))
			`uvm_fatal("DRIVER","get() failed for agt_cfg");
	endfunction

	function void connect_phase(uvm_phase phase);
		vif=agt_cfg.vif;
		$display("================================================================= %0p",vif);
	endfunction

	task run_phase(uvm_phase phase);

	@(vif.drv_cb);
	vif.drv_cb.Presetn<=1'b0;
	@(vif.drv_cb);
	vif.drv_cb.Presetn<=1'b1;

		forever
			begin
				seq_item_port.get_next_item(req);
				send_to_dut(req);
				seq_item_port.item_done();
				//req.print();

			end
	endtask

	task send_to_dut(xtn req);
		//`uvm_info("DRIVER","DATA FROM DRIVER",UVM_LOW);
			
	@(vif.drv_cb);
	vif.drv_cb.Paddr<=req.paddr;
	vif.drv_cb.Pwdata<=req.pwdata;
	vif.drv_cb.Pwrite<=req.pwrite;
	vif.drv_cb.Psel<=1'b1;
	vif.drv_cb.Penable<=1'b0;
	@(vif.drv_cb);
	vif.drv_cb.Penable<=1'b1;
	//$display("aaaaaaaaaaaaaaa");
	while(!vif.drv_cb.Pready)
		@(vif.drv_cb);
	if(req.paddr==32'h8 && req.pwrite==0)
		begin
	//$display("aaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbba");
		//	wait(vif.drv_cb.IRQ==1)

			while(vif.drv_cb.IRQ!==1)
				@(vif.drv_cb);
	//$display("aaaaaaaaaaaaaaccccffgggggggggggggggggga");

			req.IIR=vif.drv_cb.Prdata;
	$display("#########################################################");
			seq_item_port.put_response(req);
		end
		`uvm_info("DRIVER",$sformatf("DATA FROM DRIVER \n %s",req.sprint()),UVM_LOW);

	endtask



endclass






//   monitor logic

class monitor extends uvm_monitor;

	`uvm_component_utils(monitor)
	
	function new(string name="monitor",uvm_component parent);
		super.new(name,parent);
	endfunction

	virtual uart_if.MON_MP vif;

	agent_config agt_cfg;
	
	function void build_phase(uvm_phase phase);
		if(!uvm_config_db#(agent_config)::get(this,"","agent_config",agt_cfg))
			`uvm_fatal("MONITOR","get() failed for agt_cfg");
			
	endfunction

	function void connect_phase(uvm_phase phase);
		vif=agt_cfg.vif;
	endfunction

	task run_phase(uvm_phase phase);
		
		forever
			collect_data();
	endtask

	task collect_data();
	xtn xtns;
	xtns=xtn::type_id::create("xtns");

		@(vif.mon_cb);
		while(vif.mon_cb.Psel!==1)
			@(vif.mon_cb);
		//begin
			while(vif.mon_cb.Pready!==1)
				@(vif.mon_cb);
			xtns.presetn=vif.mon_cb.Presetn;
			xtns.paddr=vif.mon_cb.Paddr;
			xtns.pwdata=vif.mon_cb.Pwdata;
			xtns.pwrite=vif.mon_cb.Pwrite;
			xtns.prdata=vif.mon_cb.Prdata;
			xtns.pslaverr=vif.mon_cb.Pslverr;
			xtns.psel=vif.mon_cb.Psel;
			xtns.penable=vif.mon_cb.Penable;
			xtns.IRQ=vif.mon_cb.IRQ;
			@(vif.mon_cb);

		//update THR
		if(xtns.paddr==32'h0 && xtns.pwrite==1'b1)
			begin
				xtns.data_in_thr=1'b1;
				xtns.THR.push_back(xtns.pwdata);
			end
		
		//update RBR
		if(xtns.paddr==32'h0 && xtns.pwrite==1'b0)
			begin
				xtns.data_in_rbr=1'b1;
				xtns.RBR.push_back(xtns.pwdata);
			end

		//update LCR 
		if(xtns.paddr==32'hc && xtns.pwrite==1'b1)
			xtns.LCR=xtns.pwdata;


		//update FCR
		if(xtns.paddr==32'h8 && xtns.pwrite==1'b1)
			xtns.FCR=xtns.pwdata;
		
		//update IER
		if(xtns.paddr==32'h04 && xtns.pwrite==1'b1)
			xtns.IER=xtns.pwdata;
		
		//update DIVISOR LSB 
		if(xtns.paddr==32'h1c && xtns.pwrite==1'b1)
			begin
			xtns.DIV2[7:0]=xtns.pwdata;
			xtns.d2_access=1'b1;
			end
	
		//update DIVISOR MSB 
		if(xtns.paddr==32'h20 && xtns.pwrite==1'b1)
			begin
			xtns.DIV1[7:0]=xtns.pwdata;
			xtns.d1_access=1'b1;
			end


	//end
		`uvm_info("MONITOR",$sformatf("DATA FROM MONITOR \n %s",xtns.sprint()),UVM_LOW);

	endtask

	
endclass



