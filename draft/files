class wr_driver extends uvm_driver#(wr_xtn);

	`uvm_component_utils(wr_driver)

	wr_config w_cfg;
	
	virtual uart_if.DRV_MP vif;

	function new(string name="wr_driver",uvm_component parent);
		super.new(name,parent);
	endfunction

	function void build_phase(uvm_phase phase);
		super.build_phase(phase);
		if(!uvm_config_db #(wr_config)::get(this,"","wr_config",w_cfg))
			`uvm_fatal("WR_DRIVER","cannot get config class have you set it?");
	endfunction
	
	function void connect_phase(uvm_phase phase);
		vif = w_cfg.vif;
		$display("DRIVER %p",vif);
	endfunction

	task run_phase(uvm_phase phase);
	reset;

	forever
		begin

			seq_item_port.get_next_item(req);
			drive(req);
			seq_item_port.item_done();
		end
	endtask

	task drive(wr_xtn xtn);
	//	`uvm_info("DRIVER","Printing from DRIVER",UVM_LOW);
	//	xtn.print();
		@(vif.drv_cb);
//	$display("##################################11111111111111111111111111111#######################");

		vif.drv_cb.Paddr  <= xtn.Paddr;
		vif.drv_cb.Pwdata <= xtn.Pwdata;
		vif.drv_cb.Pwrite <= xtn.Pwrite;
		vif.drv_cb.Psel   <= 1'b1;
		vif.drv_cb.Penable<= 1'b0;
//	$display("##################################222222222222222222222222222222222#######################");

		@(vif.drv_cb);
			vif.drv_cb.Penable <= 1'b1;
//	$display("##################################33333333333333333333333333333333#######################");

		while(vif.drv_cb.Pready !==1)
			@(vif.drv_cb);
//	$display("##################################444444444444444444444444444444444#######################");
	
		if(xtn.Paddr == 32'h8 && xtn.Pwrite == 0)
			begin 
			//	$display("##################################5555555555555555555555555555555555555#######################");

				while(vif.drv_cb.IRQ !== 1)
					@(vif.drv_cb);
			//	$display("##################################666666666666666666666666666666666666666#######################");

				xtn.IIR = vif.drv_cb.Prdata;
				seq_item_port.put_response(xtn);
			end				
	endtask
	
	task reset;
		@(vif.drv_cb);
		vif.drv_cb.Presetn <= 1'b0;
		@(vif.drv_cb);
		vif.drv_cb.Presetn <= 1'b1;
	endtask
		

endclass


