class wr_monitor extends uvm_monitor;

	`uvm_component_utils(wr_monitor)

	wr_config w_cfg;
	wr_xtn xtn;

	virtual uart_if.MON_MP vif;
	
	uvm_analysis_port #(wr_xtn) mon_ap;

	function new(string name="wr_monitor",uvm_component parent);
		super.new(name,parent);
		mon_ap = new("mon_ap",this);
	endfunction

	function void build_phase(uvm_phase phase);
		super.build_phase(phase);
		xtn = wr_xtn::type_id::create("xtn");
		if(!uvm_config_db #(wr_config)::get(this,"","wr_config",w_cfg))
			`uvm_fatal("WR_MONITOR","cannot get config class have you set it?");
		
	endfunction

	function void connect_phase(uvm_phase phase);
		vif = w_cfg.vif;
		$display("MONITOR %p",vif);
	endfunction
	
	task run_phase(uvm_phase phase);
		forever
			begin 
				//xtn = wr_xtn::type_id::create("xtn");
				collect_data(xtn);
			end
	endtask

	task collect_data(wr_xtn xtn);
	
		@(vif.mon_cb);
		while(vif.mon_cb.Psel!==1)
			@(vif.mon_cb);
	
		while(vif.mon_cb.Pready !==1)
			@(vif.mon_cb);

		xtn.Paddr  = vif.mon_cb.Paddr;
		xtn.Pwdata = vif.mon_cb.Pwdata;
		xtn.Pwrite = vif.mon_cb.Pwrite;
	        xtn.Psel   = vif.mon_cb.Psel;
		xtn.Penable= vif.mon_cb.Penable;
		xtn.Pready = vif.mon_cb.Pready;
		xtn.Pslverr= vif.mon_cb.Pslverr;
		xtn.IRQ    = vif.mon_cb.IRQ;


		if(vif.mon_cb.Pwrite == 1 && vif.mon_cb.Paddr == 32'hc )
			begin 
				xtn.LCR = vif.mon_cb.Pwdata;
			end

		if(vif.mon_cb.Pwrite == 1 && vif.mon_cb.Paddr == 32'h4 )
			begin 
				xtn.IER = vif.mon_cb.Pwdata;
			end


		if(vif.mon_cb.Pwrite == 1 && vif.mon_cb.Paddr == 32'h8 )
			begin 
				xtn.FCR = vif.mon_cb.Pwdata;
			end
		
			
		if(xtn.Paddr == 32'h8 && xtn.Pwrite == 0)
			begin
				while(vif.mon_cb.IRQ !== 1)
					@(vif.mon_cb);
				xtn.IIR = vif.mon_cb.Prdata;
			end

		
		if(xtn.Paddr == 32'h14 && xtn.Pwrite == 0)
			begin 
				xtn.LSR = vif.mon_cb.Prdata;
			end

		if(xtn.Paddr == 32'h10 && xtn.Pwrite == 1)
			begin 
				xtn.MCR = vif.mon_cb.Pwdata;
			end

		//DIV1
		if(xtn.Paddr == 32'h20 && xtn.Pwrite == 1)
			begin 
				xtn.divisor[15:8] = vif.mon_cb.Pwdata;
				xtn.dl_access     = 1'b1;
			end
		//DIV2
		if(xtn.Paddr == 32'h1c && xtn.Pwrite == 1)
			begin 
				xtn.divisor[7:0] = vif.mon_cb.Pwdata;
			end

		//THR DATA
		if(vif.mon_cb.Pwrite == 1 && vif.mon_cb.Paddr == 32'h0 )
			begin 
				xtn.data_in_thr     = 1'b1;
				if(xtn.THR.size == 0 || xtn.THR[0] != vif.mon_cb.Pwdata)
				xtn.THR.push_back(vif.mon_cb.Pwdata);
			end

		//RBR DATA
		if(vif.mon_cb.Pwrite == 0 && vif.mon_cb.Paddr == 32'h0 )
			begin 
				xtn.data_in_rbr     = 1'b1;

				if(vif.mon_cb.Prdata !=0)
					xtn.RBR.push_back(vif.mon_cb.Prdata);
			end


	//	`uvm_info("MONITOR","Printing from MONITOR",UVM_LOW);
	//	xtn.print();
		mon_ap.write(xtn);
		//xtn.THR.delete();
		//$display("THR %p",xtn.THR);
		//$display("RBR %p",xtn.RBR);
	endtask
		
endclass

